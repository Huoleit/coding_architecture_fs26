            <chunk name="Object" index="76">
              <items count="3">
                <item name="GUID" type_name="gh_guid" type_code="9">27efe29a-34d5-4de3-a6ea-fca25df8766f</item>
                <item name="Lib" type_name="gh_guid" type_code="9">06126871-6c90-44c6-8d4e-8b68cc178608</item>
                <item name="Name" type_name="gh_string" type_code="10">Utilization of Elements (Karamba3D)</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="6">
                    <item name="Description" type_name="gh_string" type_code="10">Returns the utilization of beams or shells for each load case according to Eurocode 3. For shells the ratio between Van Mises Stress and yield stress is returned and buckling is not considered. 1 means 100%. By default, all elements are included.</item>
                    <item name="Hidden" type_name="gh_bool" type_code="1">true</item>
